# =============================================================================
# 信息获取助手 - 环境变量配置模板
# 复制此文件为 .env 并根据需要修改
# =============================================================================

# -----------------------------------------------------------------------------
# 应用基础配置 (可选)
# -----------------------------------------------------------------------------
DEBUG=false
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# 数据库配置 (必填)
# -----------------------------------------------------------------------------
# 方式1：使用完整 URL（推荐用于生产环境）
# DATABASE_URL=postgresql://postgres:password@localhost:5432/reading_agent

# 方式2：使用拆分字段（推荐用于开发/Docker）
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=reading_agent

# -----------------------------------------------------------------------------
# 邮件/SMTP 配置 (可选，但邮件功能需要)
# 支持任意 SMTP 服务：QQ邮箱、163邮箱、Gmail、Outlook、企业邮箱等
# -----------------------------------------------------------------------------
# QQ 邮箱示例（推荐国内用户）：
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-qq@qq.com
SMTP_PASSWORD=your-smtp-auth-code
EMAIL_FROM=your-qq@qq.com
EMAIL_TO=recipient@example.com

# 163 邮箱示例：
# SMTP_HOST=smtp.163.com
# SMTP_PORT=587
# SMTP_USER=your@163.com
# SMTP_PASSWORD=your-smtp-password
# EMAIL_FROM=your@163.com
# EMAIL_TO=recipient@example.com

# Gmail 示例（需要应用专用密码）：
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=your@gmail.com
# EMAIL_TO=recipient@example.com

# Outlook/Hotmail 示例：
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your@outlook.com
# SMTP_PASSWORD=your-password
# EMAIL_FROM=your@outlook.com
# EMAIL_TO=recipient@example.com

# 企业邮箱示例（以腾讯企业邮为例，注意 port 465 需要 SMTP_USE_SSL=true）：
# SMTP_HOST=smtp.exmail.qq.com
# SMTP_PORT=465
# SMTP_USE_SSL=true
# SMTP_USER=your@company.com
# SMTP_PASSWORD=your-password
# EMAIL_FROM=your@company.com
# EMAIL_TO=recipient@example.com

# -----------------------------------------------------------------------------
# 调度器配置 (可选)
# -----------------------------------------------------------------------------
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_FETCH_TIME=06:00
SCHEDULER_RECOMMEND_TIME=06:30
SCHEDULER_EMAIL_TIME=07:00

# -----------------------------------------------------------------------------
# 看板/Dashboard URL (可选)
# -----------------------------------------------------------------------------
DASHBOARD_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# RSS 源配置 (可选)
# -----------------------------------------------------------------------------
RSSHUB_URL=https://rsshub.app
RSSHUB_USER_AGENT=Mozilla/5.0 (compatible; InformationAcquisitionAssistant/1.0)
RSSHUB_TIMEOUT=30

# -----------------------------------------------------------------------------
# 推荐系统配置 (可选)
# -----------------------------------------------------------------------------
DEFAULT_RECOMMENDATION_LIMIT=10
EXPLORATION_RATIO=0.3

# -----------------------------------------------------------------------------
# LLM / Embedding 服务 (预留，当前版本未启用)
# 如需启用智能摘要、标签生成等功能，请配置
# -----------------------------------------------------------------------------
# LLM_API_KEY=your-llm-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=your-embedding-api-key
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# =============================================================================
# 快速开始检查清单：
# 1. 复制本文件：cp .env.example .env
# 2. 修改数据库密码（如使用 Docker 可保持默认）
# 3. 如需邮件功能，填写 SMTP 配置
# 4. 运行：docker-compose up -d
# 5. 访问：http://localhost:8000
# =============================================================================
